  {
    id: 21, nbhd: "park", cat: "service", emoji: "🪐",
    lat: 32.1023938, lng: 34.7939174,
    website: "https://www.eretzmuseum.org.il/en/planetarium/",
    en: { name: "Laski Planetarium", role: "Planetarium", zone: "Western park",
         desc: "Dedicated in 1968 and donated by Harry and Sadie Lasky, the planetarium projects an artificial sky onto a 12-metre dome — Israel’s largest domed screen — using a state-of-the-art Digistar 7 laser system, with seating for 110. It runs short shows for ages 5 and up, including “Stars” (a voyage across galaxies and the life and death of stars) and “Astronaut” (how astronauts train for spaceflight).",
         tip: "Shows run to a schedule and may need a separate ticket — check times at the entrance." },
    he: { name: "פלנטריום ע“ש לסקי", role: "פלנטריום", zone: "מתחם הבוסתן המערבי",
         desc: "הפלנטריום, שנחנך ב-1968 בתרומת הארי וסיידי לסקי, מקרין שמיים מלאכותיים על כיפה בקוטר 12 מטר — מסך הכיפה הגדול בישראל — באמצעות מערכת לייזר Digistar 7 מתקדמת, ובו 110 מושבים. מוצגות בו תוכניות קצרות לכל המשפחה מגיל 5 ומעלה, ובהן “כוכבים” (מסע בין גלקסיות וסיפור חייהם ומותם של כוכבים) ו“אסטרונאוט” (כיצד מתאמנים אסטרונאוטים לקראת טיסה לחלל).",
         tip: "ההקרנות לפי לוח זמנים ועשויות לדרוש כרטיס נפרד — בדקו שעות בכניסה." },
  },
