// Coordinates from OpenStreetMap building centroids. Exhibitions current as of 26 Jun 2026.

const PLACES = [
  {
    id: 1, nbhd: "east", cat: "pavilion", emoji: "🏺",
    lat: 32.1028378, lng: 34.7978806,
    website: "https://www.eretzmuseum.org.il/en/the-ceramics-pavilion/",
    en: { name: "Ceramics Pavilion", role: "Permanent collection", zone: "Eastern pavilions",
         desc: "Opened in 1966, the pavilion traces ceramics across seven sections — from the first fired-clay vessels of the Neolithic and Chalcolithic periods, through manufacturing, decoration and the role of pottery in early writing, to ritual art. Highlights: painted Neolithic potsherds, clay ossuaries, Greek black- and red-figure vessels, Islamic blue-glazed pottery, finds from the temples of Tell Qasile, and a full-scale reconstruction of a 3,000-year-old Israelite “Four-Room House”. The renewed courtyard adds contemporary works by Lidia Zavadsky and Uriel Caspi.",
         tip: "In the eastern cluster, beside the Glass and Nehushtan pavilions." },
    he: { name: "ביתן הקרמיקה", role: "תצוגת קבע", zone: "מתחם הביתנים המזרחי",
         desc: "הביתן, שנפתח ב-1966, מתחקה אחר תולדות הקרמיקה בשבעה חלקים — מכלי החרס השרופים הראשונים של התקופות הניאוליתית והכלקוליתית, דרך טכניקות ייצור ועיטור ותפקיד החרס בראשית הכתב, ועד אמנות ופולחן. בין המוצגים: שברי כלים ניאוליתיים מצוירים, גלוסקמאות חרס, כלים יווניים בטכניקת הדמויות השחורות והאדומות, קרמיקה אסלאמית בזיגוג כחול, ממצאים ממקדשי תל קסילה, ושחזור בגודל מלא של “בית ארבעת המרחבים” הישראלי בן 3,000 השנה. בחצר המחודשת מוצגות עבודות עכשוויות של לידיה זבצקי ואוריאל כספי.",
         tip: "במתחם המזרחי, ליד ביתני הזכוכית ונחושתן." },
  },
  {
    id: 2, nbhd: "east", cat: "pavilion", emoji: "🫙",
    lat: 32.1024233, lng: 34.7972721,
    website: "https://www.eretzmuseum.org.il/en/the-glass-pavilion/",
    en: { name: "Glass Pavilion", role: "Permanent collection", zone: "Eastern pavilions",
         desc: "Built in 1959 around founder Dr. Walter Moses’s collection, this is one of the world’s finest collections of ancient glass — a permanent display spanning 3,000 years, from the ancient Near East to the decline of Islamic glass around 1400 CE. It runs from pre-blown glass through Roman and Byzantine blown glass to the Islamic period, ending at a Crusader-era glass furnace. Star pieces: Ennion’s signed Blue Jug, a rare Roman drinking horn, a gold-glass mosaic panel from Caesarea, and a 14th-century Mamluk mosque lamp.",
         tip: "Lit low to protect the glass — give your eyes a moment." },
    he: { name: "ביתן הזכוכית", role: "תצוגת קבע", zone: "מתחם הביתנים המזרחי",
         desc: "ביתן הזכוכית, שנבנה ב-1959 על בסיס אוסף מייסד המוזיאון ד’ר ולטר מוזס, מציג את אחד מאוספי הזכוכית העתיקה המשובחים בעולם — תצוגת קבע הפרושה על פני 3,000 שנה, מן המזרח הקדום ועד שקיעת זכוכית האסלאם סביב שנת 1400. התצוגה נעה מזכוכית טרום-ניפוח, דרך זכוכית מנופחת מן התקופות הרומית והביזנטית, ועד התקופה האסלאמית, ומסתיימת בכבשן זכוכית מן התקופה הצלבנית. בין פריטי המופת: הפך הכחול החתום של אניון, קרן שתייה רומית נדירה, לוח זכוכית-זהב ופסיפס מקיסריה, ומנורת מסגד ממלוכית מן המאה ה-14.",
         tip: "התצוגה מוארת בעמעום כדי להגן על הזכוכית — תנו לעיניים רגע להתרגל." },
  },
  {
    id: 3, nbhd: "east", cat: "pavilion", emoji: "🪙",
    lat: 32.1031281, lng: 34.7970486,
    website: "https://www.eretzmuseum.org.il/en/kadman-numismatic-pavilion/",
    en: { name: "Kadman Numismatic Pavilion", role: "Permanent collection", zone: "Eastern pavilions",
         desc: "Inaugurated in 1962 around the collection of Leo Kadman, this is the largest numismatic collection in Israel and one of the largest in the world — tens of thousands of coins, banknotes, weights and medals. The display follows means of payment from pre-coinage barter (salt, shells, hacksilver) through the first Greek coins, the coins minted in the Land of Israel (Yehud, Hasmonean, Herodian, the Jewish War and Bar Kokhba Revolt), and the region under foreign rule, up to modern Israeli coins that echo ancient Jewish designs.",
         tip: "At the north-eastern edge, near the Alexander Pavilion." },
    he: { name: "ביתן קדמן למטבעות", role: "תצוגת קבע", zone: "מתחם הביתנים המזרחי",
         desc: "הביתן, שנחנך ב-1962 סביב אוסף המטבעות של ליאו קדמן, הוא אוסף המטבעות הגדול בישראל ומן הגדולים בעולם — עשרות אלפי מטבעות, שטרות, משקלות ומדליות. התצוגה עוקבת אחר אמצעי התשלום מסחר-החליפין שקדם למטבע (מלח, צדפים, נתחי כסף), דרך המטבעות היווניים הראשונים, המטבעות שהוטבעו בארץ ישראל (יהוד, חשמונאי, הורדוסי, מרד החורבן ומרד בר-כוכבא), והארץ תחת שלטון זר, ועד מטבעות מדינת ישראל המודרניים, שעיצובם שואב מן המטבעות היהודיים הקדומים.",
         tip: "בקצה הצפוני-מזרחי, ליד ביתן אלכסנדר." },
