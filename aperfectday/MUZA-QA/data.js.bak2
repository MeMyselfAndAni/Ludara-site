  {
    id: 13, nbhd: "core", cat: "heritage", emoji: "🧩",
    lat: 32.1030522, lng: 34.7957828,
    website: "https://www.eretzmuseum.org.il/en/open-spaces/",
    en: { name: "Square of Mosaic Floors", role: "Ancient mosaics", zone: "Central core",
         desc: "Ancient mosaic floors gathered from sites across Israel and laid out together in the open air — among them a 6th-century Samaritan prayer-house floor (in situ), a hunting-scene floor from Beit Guvrin, a Tiberias synagogue floor with lulavim and etrogim, and a Muslim prayer-house floor from Ramla. Together they testify to the many cultures — Samaritan, Jewish, Christian and Muslim — that lived here.",
         tip: "Best seen in raking morning or late-afternoon light." },
    he: { name: "כיכר הפסיפסים", role: "פסיפסים עתיקים", zone: "מתחם המרכז",
         desc: "רצפות פסיפס עתיקות שנאספו מאתרים ברחבי הארץ והוצבו יחד תחת כיפת השמיים — ביניהן רצפת בית-תפילה שומרוני מן המאה ה-6 (במקומה המקורי), רצפת סצנות ציד מבית גוברין, רצפת בית כנסת מטבריה ובה לולבים ואתרוגים, ורצפת בית-תפילה מוסלמי מרמלה. יחד הן מעידות על שלל התרבויות — שומרונית, יהודית, נוצרית ומוסלמית — שחיו כאן.",
         tip: "נראות במיטבן באור נמוך של בוקר או של אחר הצהריים." },
  },
  {
    id: 14, nbhd: "park", cat: "heritage", emoji: "🫒",
    lat: 32.1014195, lng: 34.7942218,
    website: "https://www.eretzmuseum.org.il/en/open-spaces/",
    en: { name: "Olive Press (Beit Ha’Bad)", role: "Reconstructed olive-oil plant", zone: "Western park",
